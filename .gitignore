# Tender input documents (binary files — add manually)
tenders/**/input/*.pdf
tenders/**/input/*.docx

# Output documents generated by the agent
tenders/**/output/*.docx
tenders/**/output/*.pdf
tenders/**/output/*.md

# Keep directory structure in source control
!tenders/**/output/.gitkeep
!tenders/**/input/README.md

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.pyo
.env
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
*.pyc
