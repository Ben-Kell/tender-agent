# Copy this file to .env and fill in your values.

# OpenAI API key (required)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model to use for all completions (default: gpt-4o)
OPENAI_MODEL=gpt-5

# GitHub personal access token for fetching repository files via the API
# Leave blank to make unauthenticated requests (lower rate limits)
GITHUB_TOKEN=your-github-token-here

# GitHub repository to load prompts and templates from
GITHUB_REPO=Ben-Kell/tender-agent

# Branch to target when fetching files from GitHub
GITHUB_BRANCH=main
